# ==============================================================================
# wechat-ai-bot configuration
# Copy this file to .env and fill in your values
# ==============================================================================

# ----- wkteam WeChat Gateway -----
# Get these from https://wkteam.cn after purchasing their service
WKTEAM_API_URL=
WKTEAM_TOKEN=
WKTEAM_WID=
BOT_WCID=

# ----- Claude Agent SDK -----
# Standard Anthropic API, or compatible endpoint (e.g., self-hosted)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# ----- Security -----
# Random string used in webhook URL path; only wkteam knows the full URL
WEBHOOK_SECRET=change-me-to-random-string

# ----- Group whitelist -----
# Comma-separated chatroom IDs; leave empty to allow all groups
# Example: 12345678901@chatroom,23456789012@chatroom
ALLOWED_GROUPS=

# ----- Service -----
PORT=8000
